# ============================================================
# secrets.toml.example
# ============================================================
# Este archivo es un TEMPLATE. No contiene claves reales.
#
# Para uso LOCAL:
#   1. Copiá este archivo a .streamlit/secrets.toml
#   2. Reemplazá el valor con tu API key real de Anthropic
#   (secrets.toml está en .gitignore — nunca se sube a GitHub)
#
# Para Streamlit Community Cloud:
#   No uses este archivo. Configurá la key directamente
#   en el dashboard de Streamlit Cloud:
#   App settings → Secrets → pegar el contenido de abajo
# ============================================================

ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
